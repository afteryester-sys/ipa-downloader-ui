<Application x:Class="IPAStudio.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:IPAStudio.App.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Theme.xaml" />
                <!-- Language dictionary is swapped at runtime by LocalizationManager -->
                <ResourceDictionary Source="Resources/Strings.ru.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <conv:StringEqualsConverter x:Key="StringEquals" />
            <conv:IntEqualsConverter x:Key="IntEquals" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
