<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">

    <!-- Common -->
    <sys:String x:Key="L.AppTitle">IPA Studio</sys:String>
    <sys:String x:Key="L.Back">Back</sys:String>
    <sys:String x:Key="L.Cancel">Cancel</sys:String>
    <sys:String x:Key="L.Retry">Retry</sys:String>
    <sys:String x:Key="L.Settings">Settings</sys:String>
    <sys:String x:Key="L.Search">Search…</sys:String>
    <sys:String x:Key="L.Loading">Loading…</sys:String>
    <sys:String x:Key="L.Credit">developed by Poslevcherashniy</sys:String>

    <!-- Environment setup -->
    <sys:String x:Key="L.Setup.Title">Environment Check</sys:String>
    <sys:String x:Key="L.Setup.Subtitle">Making sure everything needed to work with your iPhone is installed</sys:String>
    <sys:String x:Key="L.Setup.Drivers">Apple drivers (Apple Mobile Device Support)</sys:String>
    <sys:String x:Key="L.Setup.DriversHint">Required for Windows to detect a connected iPhone. Installed together with iTunes.</sys:String>
    <sys:String x:Key="L.Setup.ITunes">iTunes</sys:String>
    <sys:String x:Key="L.Setup.ITunesHint">Recommended. Provides drivers and reliable device connectivity.</sys:String>
    <sys:String x:Key="L.Setup.Tools">Helper utilities (ipatool, libimobiledevice)</sys:String>
    <sys:String x:Key="L.Setup.ToolsHint">Downloaded automatically. Needed to download and install apps.</sys:String>
    <sys:String x:Key="L.Setup.Install">Install</sys:String>
    <sys:String x:Key="L.Setup.Installing">Installing… A User Account Control (UAC) prompt may appear.</sys:String>
    <sys:String x:Key="L.Setup.Recheck">Check again</sys:String>
    <sys:String x:Key="L.Setup.Skip">Skip</sys:String>
    <sys:String x:Key="L.Setup.ITunesFailed">Could not install iTunes automatically. Please install it manually from apple.com and click "Check again".</sys:String>
    <sys:String x:Key="L.Setup.ToolsFailed">Could not download the helper utilities. Check your internet connection and retry.</sys:String>

    <!-- Login -->
    <sys:String x:Key="L.Login.Title">Sign in with Apple ID</sys:String>
    <sys:String x:Key="L.Login.Subtitle">Sign in to download apps from the App Store</sys:String>
    <sys:String x:Key="L.Login.Email">Apple ID (email)</sys:String>
    <sys:String x:Key="L.Login.Password">Password</sys:String>
    <sys:String x:Key="L.Login.SignIn">Sign In</sys:String>
    <sys:String x:Key="L.Login.TwoFactorTitle">Two-Factor Authentication</sys:String>
    <sys:String x:Key="L.Login.TwoFactorHint">Enter the 6-digit code sent to your Apple devices</sys:String>
    <sys:String x:Key="L.Login.Confirm">Confirm</sys:String>
    <sys:String x:Key="L.Login.SigningIn">Signing in…</sys:String>
    <sys:String x:Key="L.Login.RestoringSession">Checking saved session…</sys:String>

    <!-- Devices -->
    <sys:String x:Key="L.Devices.Title">Devices</sys:String>
    <sys:String x:Key="L.Devices.Subtitle">Connect an iPhone or iPad via USB and select it</sys:String>
    <sys:String x:Key="L.Devices.Empty">Waiting for a device…</sys:String>
    <sys:String x:Key="L.Devices.EmptyHint">Make sure Apple Mobile Device Support (iTunes) is installed and the device is unlocked. Tap "Trust" on the device.</sys:String>
    <sys:String x:Key="L.Devices.Battery">Battery</sys:String>
    <sys:String x:Key="L.Devices.Select">Select</sys:String>
    <sys:String x:Key="L.Devices.Connected">Connected</sys:String>
    <sys:String x:Key="L.Devices.Catalog">App Catalog</sys:String>
    <sys:String x:Key="L.Devices.CatalogApps">apps in catalog</sys:String>
    <sys:String x:Key="L.Devices.SignOut">Sign Out</sys:String>

    <!-- App picker -->
    <sys:String x:Key="L.Picker.Title">Choose Apps</sys:String>
    <sys:String x:Key="L.Picker.SearchPlaceholder">Search</sys:String>
    <sys:String x:Key="L.Picker.SelectedCount">Selected:</sys:String>
    <sys:String x:Key="L.Picker.Install">Install Selected</sys:String>
    <sys:String x:Key="L.Picker.SelectAll">Select All</sys:String>
    <sys:String x:Key="L.Picker.ClearAll">Clear Selection</sys:String>
    <sys:String x:Key="L.Picker.All">All</sys:String>
    <sys:String x:Key="L.Picker.RefreshingStatuses">Refreshing statuses…</sys:String>
    <sys:String x:Key="L.Status.Downloaded">Downloaded</sys:String>
    <sys:String x:Key="L.Status.Licensed">Licensed</sys:String>
    <sys:String x:Key="L.Status.NotLicensed">No License</sys:String>
    <sys:String x:Key="L.Status.Installed">Installed</sys:String>

    <!-- Queue -->
    <sys:String x:Key="L.Queue.Title">Installing Apps</sys:String>
    <sys:String x:Key="L.Queue.Overall">Overall Progress</sys:String>
    <sys:String x:Key="L.Queue.Done">Done</sys:String>
    <sys:String x:Key="L.Queue.Failed">Failed</sys:String>
    <sys:String x:Key="L.Queue.Cancelled">Cancelled</sys:String>
    <sys:String x:Key="L.Queue.CancelAll">Cancel All</sys:String>
    <sys:String x:Key="L.Queue.Finish">Finish</sys:String>
    <sys:String x:Key="L.Stage.Pending">Queued</sys:String>
    <sys:String x:Key="L.Stage.Checking">Checking</sys:String>
    <sys:String x:Key="L.Stage.Licensing">License</sys:String>
    <sys:String x:Key="L.Stage.Downloading">Download</sys:String>
    <sys:String x:Key="L.Stage.Installing">Install</sys:String>

    <!-- Settings -->
    <sys:String x:Key="L.Settings.Title">Settings</sys:String>
    <sys:String x:Key="L.Settings.Language">Interface Language</sys:String>
    <sys:String x:Key="L.Settings.IpatoolVersion">ipatool version</sys:String>
    <sys:String x:Key="L.Settings.IpatoolV2">v2 — no iCloud required (recommended)</sys:String>
    <sys:String x:Key="L.Settings.IpatoolV3">v3 — requires iCloud installed</sys:String>
    <sys:String x:Key="L.Settings.AppsFolder">IPA download folder</sys:String>
    <sys:String x:Key="L.Settings.ParallelDownloads">Parallel downloads</sys:String>
    <sys:String x:Key="L.Settings.Account">Account</sys:String>
    <sys:String x:Key="L.Settings.SignOut">Sign out of Apple ID</sys:String>
    <sys:String x:Key="L.Settings.Save">Save</sys:String>

    <!-- Updates -->
    <sys:String x:Key="L.Update.Title">Updates</sys:String>
    <sys:String x:Key="L.Update.Version">Current version:</sys:String>
    <sys:String x:Key="L.Update.Check">Check for updates</sys:String>
    <sys:String x:Key="L.Update.Download">Download update</sys:String>
    <sys:String x:Key="L.Update.Install">Install and restart</sys:String>
    <sys:String x:Key="L.Update.Checking">Checking for updates…</sys:String>
    <sys:String x:Key="L.Update.Available">A new version {0} is available</sys:String>
    <sys:String x:Key="L.Update.UpToDate">You are running the latest version</sys:String>
    <sys:String x:Key="L.Update.UpToDateVer">You are running the latest version (v{0})</sys:String>
    <sys:String x:Key="L.Update.Downloading">Downloading update…</sys:String>
    <sys:String x:Key="L.Update.Ready">Update downloaded. Click "Install and restart".</sys:String>
    <sys:String x:Key="L.Update.OpenedBrowser">The releases page was opened in your browser — download the installer manually.</sys:String>
    <sys:String x:Key="L.Update.Failed">Could not check for updates.</sys:String>
    <sys:String x:Key="L.Update.NoReleases">No updates: no release has been published on the server yet.</sys:String>
    <sys:String x:Key="L.Update.NoConnection">Could not reach the update server. Check your internet connection.</sys:String>
    <sys:String x:Key="L.Update.Timeout">The update server timed out. Please try again.</sys:String>
    <sys:String x:Key="L.Update.ServerError">The update server returned an error: {0}</sys:String>
    <sys:String x:Key="L.Update.BadResponse">Could not parse the update server response.</sys:String>

    <!-- Menu (gear) -->
    <sys:String x:Key="L.Menu.Title">Menu</sys:String>
    <sys:String x:Key="L.Menu.Diagnostics">Diagnostics</sys:String>
    <sys:String x:Key="L.Menu.Logs">Show log</sys:String>

    <!-- Logs -->
    <sys:String x:Key="L.Logs.Title">Application log</sys:String>
    <sys:String x:Key="L.Logs.Hint">Detailed activity log. Copy it and send it to the developer to help diagnose an error.</sys:String>
    <sys:String x:Key="L.Logs.Copy">Copy all</sys:String>
    <sys:String x:Key="L.Logs.Refresh">Refresh</sys:String>
    <sys:String x:Key="L.Logs.OpenFile">Open file</sys:String>
    <sys:String x:Key="L.Logs.Clear">Clear</sys:String>
    <sys:String x:Key="L.Logs.File">Log file:</sys:String>

</ResourceDictionary>
