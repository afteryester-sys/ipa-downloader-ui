<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============ Dark palette (5 colors) ============
         Primary accent:  #0A84FF (iOS blue)
         Neutrals:        #101014 (bg), #1B1B21 (surface), #EDEDF2 (text)
         Accent 2:        #30D158 (success green)
    -->
    <Color x:Key="Color.Background">#101014</Color>
    <Color x:Key="Color.Surface">#1B1B21</Color>
    <Color x:Key="Color.SurfaceHover">#24242C</Color>
    <Color x:Key="Color.Border">#2E2E38</Color>
    <Color x:Key="Color.Text">#EDEDF2</Color>
    <Color x:Key="Color.TextMuted">#9A9AA6</Color>
    <Color x:Key="Color.Accent">#0A84FF</Color>
    <Color x:Key="Color.AccentDim">#0A84FF</Color>
    <Color x:Key="Color.Success">#30D158</Color>
    <Color x:Key="Color.Danger">#FF453A</Color>
    <Color x:Key="Color.Warning">#FFD60A</Color>

    <SolidColorBrush x:Key="Brush.Background" Color="{StaticResource Color.Background}" />
    <SolidColorBrush x:Key="Brush.Surface" Color="{StaticResource Color.Surface}" />
    <SolidColorBrush x:Key="Brush.SurfaceHover" Color="{StaticResource Color.SurfaceHover}" />
    <SolidColorBrush x:Key="Brush.Border" Color="{StaticResource Color.Border}" />
    <SolidColorBrush x:Key="Brush.Text" Color="{StaticResource Color.Text}" />
    <SolidColorBrush x:Key="Brush.TextMuted" Color="{StaticResource Color.TextMuted}" />
    <SolidColorBrush x:Key="Brush.Accent" Color="{StaticResource Color.Accent}" />
    <SolidColorBrush x:Key="Brush.Success" Color="{StaticResource Color.Success}" />
    <SolidColorBrush x:Key="Brush.Danger" Color="{StaticResource Color.Danger}" />
    <SolidColorBrush x:Key="Brush.Warning" Color="{StaticResource Color.Warning}" />
    <SolidColorBrush x:Key="Brush.AccentSoft" Color="#1F0A84FF" />
    <SolidColorBrush x:Key="Brush.SuccessSoft" Color="#1F30D158" />
    <SolidColorBrush x:Key="Brush.DangerSoft" Color="#1FFF453A" />
    <SolidColorBrush x:Key="Brush.WarningSoft" Color="#1FFFD60A" />

</ResourceDictionary>
