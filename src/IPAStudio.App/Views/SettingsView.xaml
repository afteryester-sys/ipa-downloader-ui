<UserControl x:Class="IPAStudio.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=System.Runtime"
             xmlns:conv="clr-namespace:IPAStudio.App.Converters">
    <UserControl.Resources>
        <sys:Int32 x:Key="V2">2</sys:Int32>
        <sys:Int32 x:Key="V3">3</sys:Int32>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:NullToCollapsedConverter x:Key="NullToCollapsed" />
        <conv:InverseBoolConverter x:Key="InverseBool" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32" MaxWidth="560" HorizontalAlignment="Left">

            <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                <Button Content="{DynamicResource L.Back}" Style="{StaticResource Button.Ghost}"
                        Command="{Binding GoBackCommand}" VerticalAlignment="Center" Margin="0,0,16,0" />
                <TextBlock Text="{DynamicResource L.Settings.Title}" Style="{StaticResource Text.Title}" />
            </StackPanel>

            <!-- Language -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{DynamicResource L.Settings.Language}" Style="{StaticResource Text.Body}"
                               FontWeight="SemiBold" Margin="0,0,0,10" />
                    <StackPanel Orientation="Horizontal">
                        <RadioButton Content="Русский" GroupName="Lang" Foreground="{StaticResource Brush.Text}"
                                     IsChecked="{Binding Language, Converter={StaticResource StringEquals}, ConverterParameter=ru}"
                                     Margin="0,0,20,0" />
                        <RadioButton Content="English" GroupName="Lang" Foreground="{StaticResource Brush.Text}"
                                     IsChecked="{Binding Language, Converter={StaticResource StringEquals}, ConverterParameter=en}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ipatool version -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{DynamicResource L.Settings.IpatoolVersion}" Style="{StaticResource Text.Body}"
                               FontWeight="SemiBold" Margin="0,0,0,10" />
                    <RadioButton Content="{DynamicResource L.Settings.IpatoolV2}" GroupName="Ipatool"
                                 Foreground="{StaticResource Brush.Text}" Margin="0,0,0,8"
                                 IsChecked="{Binding IpatoolVersion, Converter={StaticResource IntEquals}, ConverterParameter={StaticResource V2}}" />
                    <RadioButton Content="{DynamicResource L.Settings.IpatoolV3}" GroupName="Ipatool"
                                 Foreground="{StaticResource Brush.Text}"
                                 IsChecked="{Binding IpatoolVersion, Converter={StaticResource IntEquals}, ConverterParameter={StaticResource V3}}" />
                </StackPanel>
            </Border>

            <!-- Apps folder -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{DynamicResource L.Settings.AppsFolder}" Style="{StaticResource Text.Body}"
                               FontWeight="SemiBold" Margin="0,0,0,10" />
                    <TextBox Style="{StaticResource Input.TextBox}"
                             Text="{Binding AppsFolder, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
            </Border>

            <!-- Parallel downloads -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <Grid Margin="0,0,0,10">
                        <TextBlock Text="{DynamicResource L.Settings.ParallelDownloads}" Style="{StaticResource Text.Body}"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="{Binding MaxParallelDownloads}" Style="{StaticResource Text.Body}"
                                   FontWeight="SemiBold" Foreground="{StaticResource Brush.Accent}"
                                   HorizontalAlignment="Right" />
                    </Grid>
                    <Slider Minimum="1" Maximum="5" TickFrequency="1" IsSnapToTickEnabled="True"
                            Value="{Binding MaxParallelDownloads}" />
                </StackPanel>
            </Border>

            <!-- Account -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="{DynamicResource L.Settings.Account}" Style="{StaticResource Text.Body}"
                               FontWeight="SemiBold" Margin="0,0,0,6" />
                    <TextBlock Text="{Binding AccountEmail}" Style="{StaticResource Text.Caption}" Margin="0,0,0,12" />
                    <Button Content="{DynamicResource L.Settings.SignOut}" Style="{StaticResource Button.Danger}"
                            HorizontalAlignment="Left"
                            Command="{Binding SignOutCommand}" />
                </StackPanel>
            </Border>

            <!-- Updates -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,24">
                <StackPanel>
                    <Grid Margin="0,0,0,10">
                        <TextBlock Text="{DynamicResource L.Update.Title}" Style="{StaticResource Text.Body}"
                                   FontWeight="SemiBold" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBlock Text="{DynamicResource L.Update.Version}" Style="{StaticResource Text.Caption}"
                                       VerticalAlignment="Center" Margin="0,0,4,0" />
                            <TextBlock Text="{Binding CurrentVersion}" Style="{StaticResource Text.Caption}"
                                       Foreground="{StaticResource Brush.Accent}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="{Binding UpdateStatus}" Style="{StaticResource Text.Caption}"
                               TextWrapping="Wrap" Margin="0,0,0,12"
                               Visibility="{Binding UpdateStatus, Converter={StaticResource NullToCollapsed}}" />

                    <!-- Download progress -->
                    <ProgressBar Style="{StaticResource Progress.Slim}" Minimum="0" Maximum="1"
                                 Value="{Binding UpdateProgress}" Margin="0,0,0,12"
                                 Visibility="{Binding IsDownloadingUpdate, Converter={StaticResource BoolToVis}}" />

                    <StackPanel Orientation="Horizontal">
                        <Button Content="{DynamicResource L.Update.Check}" Style="{StaticResource Button.Secondary}"
                                Command="{Binding CheckUpdateCommand}" IsEnabled="{Binding IsUpdateBusy, Converter={StaticResource InverseBool}}"
                                Margin="0,0,10,0" />
                        <Button Content="{DynamicResource L.Update.Download}" Style="{StaticResource Button.Primary}"
                                Command="{Binding DownloadUpdateCommand}"
                                IsEnabled="{Binding IsUpdateBusy, Converter={StaticResource InverseBool}}"
                                Visibility="{Binding UpdateAvailable, Converter={StaticResource BoolToVis}}"
                                Margin="0,0,10,0" />
                        <Button Content="{DynamicResource L.Update.Install}" Style="{StaticResource Button.Primary}"
                                Command="{Binding InstallUpdateCommand}"
                                Visibility="{Binding UpdateReady, Converter={StaticResource BoolToVis}}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Button Content="{DynamicResource L.Settings.Save}" Style="{StaticResource Button.Primary}"
                    HorizontalAlignment="Left" Padding="32,12"
                    Command="{Binding SaveCommand}" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
