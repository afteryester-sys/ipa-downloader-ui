<UserControl x:Class="IPAStudio.App.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:IPAStudio.App.Converters">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:NullToCollapsedConverter x:Key="NullToCollapsed" />
    </UserControl.Resources>

    <Grid>
        <Border Style="{StaticResource Card}" Width="420" Padding="36"
                HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel>

                <!-- Minimal logo mark -->
                <Border Width="44" Height="44" CornerRadius="12"
                        Background="{StaticResource Brush.AccentSoft}"
                        HorizontalAlignment="Center" Margin="0,0,0,16">
                    <TextBlock Text="&#xE753;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                               Foreground="{StaticResource Brush.Accent}"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>

                <TextBlock Text="{DynamicResource L.Login.Title}" Style="{StaticResource Text.Title}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="{DynamicResource L.Login.Subtitle}" Style="{StaticResource Text.Subtitle}"
                           HorizontalAlignment="Center" TextAlignment="Center" Margin="0,8,0,28" />

                <!-- Session restore indicator -->
                <StackPanel Visibility="{Binding IsRestoringSession, Converter={StaticResource BoolToVis}}"
                            HorizontalAlignment="Center" Margin="0,0,0,16">
                    <ProgressBar Style="{StaticResource Progress.Slim}" IsIndeterminate="True" Width="220" />
                    <TextBlock Text="{DynamicResource L.Login.RestoringSession}"
                               Style="{StaticResource Text.Caption}" HorizontalAlignment="Center" Margin="0,8,0,0" />
                </StackPanel>

                <!-- Step 1: credentials -->
                <StackPanel Visibility="{Binding IsTwoFactorStep, Converter={StaticResource BoolToVis}, ConverterParameter=invert}">
                    <TextBlock Text="{DynamicResource L.Login.Email}" Style="{StaticResource Text.Caption}" Margin="0,0,0,6" />
                    <TextBox Style="{StaticResource Input.TextBox}"
                             Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Text="{DynamicResource L.Login.Password}" Style="{StaticResource Text.Caption}" Margin="0,16,0,6" />
                    <PasswordBox x:Name="PasswordInput" Style="{StaticResource Input.PasswordBox}"
                                 PasswordChanged="OnPasswordChanged" KeyDown="OnPasswordKeyDown" />

                    <Button Content="{DynamicResource L.Login.SignIn}" Style="{StaticResource Button.Primary}"
                            Command="{Binding SignInCommand}" Margin="0,24,0,0"
                            HorizontalAlignment="Stretch" />

                    <Button Content="{DynamicResource L.Login.Skip}" Style="{StaticResource Button.Ghost}"
                            Command="{Binding SkipCommand}" Margin="0,8,0,0"
                            HorizontalAlignment="Center" />
                    <TextBlock Text="{DynamicResource L.Login.SkipHint}" Style="{StaticResource Text.Caption}"
                               TextWrapping="Wrap" TextAlignment="Center" Margin="0,4,0,0" />
                </StackPanel>

                <!-- Step 2: two-factor code -->
                <StackPanel Visibility="{Binding IsTwoFactorStep, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{DynamicResource L.Login.TwoFactorTitle}" Style="{StaticResource Text.Body}"
                               FontWeight="SemiBold" HorizontalAlignment="Center" />
                    <TextBlock Text="{DynamicResource L.Login.TwoFactorHint}" Style="{StaticResource Text.Caption}"
                               TextWrapping="Wrap" TextAlignment="Center" Margin="0,6,0,16" />

                    <TextBox Style="{StaticResource Input.TextBox}" MaxLength="6"
                             FontSize="24" TextAlignment="Center"
                             Text="{Binding TwoFactorCode, UpdateSourceTrigger=PropertyChanged}" />

                    <Button Content="{DynamicResource L.Login.Confirm}" Style="{StaticResource Button.Primary}"
                            Command="{Binding ConfirmTwoFactorCommand}" Margin="0,20,0,0"
                            HorizontalAlignment="Stretch" />

                    <!-- "Code didn't arrive?" row -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
                        <TextBlock Text="{DynamicResource L.Login.CodeNotArrived}"
                                   Style="{StaticResource Text.Caption}" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <Button Content="{DynamicResource L.Login.ResendCode}"
                                Style="{StaticResource Button.Ghost}"
                                Command="{Binding ResendCodeCommand}"
                                Padding="8,4" FontSize="12" />
                    </StackPanel>

                    <Button Content="{DynamicResource L.Back}" Style="{StaticResource Button.Ghost}"
                            Command="{Binding BackToCredentialsCommand}" Margin="0,6,0,0"
                            HorizontalAlignment="Center" />
                </StackPanel>

                <!-- Busy indicator -->
                <StackPanel Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" Margin="0,20,0,0">
                    <ProgressBar Style="{StaticResource Progress.Slim}" IsIndeterminate="True" />
                    <TextBlock Text="{DynamicResource L.Login.SigningIn}" Style="{StaticResource Text.Caption}"
                               HorizontalAlignment="Center" Margin="0,8,0,0" />
                </StackPanel>

                <!-- iCloud Not Found banner (ipatool v3 only) -->
                <Border Background="{StaticResource Brush.DangerSoft}"
                        BorderBrush="{StaticResource Brush.Danger}" BorderThickness="1"
                        CornerRadius="8" Padding="14,12" Margin="0,20,0,0"
                        Visibility="{Binding IsICloudError, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource L.Login.ICloudTitle}"
                                   Foreground="{StaticResource Brush.Danger}"
                                   FontWeight="SemiBold" FontSize="13" />
                        <TextBlock Text="{DynamicResource L.Login.ICloudHint}"
                                   Foreground="{StaticResource Brush.Danger}"
                                   FontSize="12" TextWrapping="Wrap" Margin="0,4,0,10" />
                        <Button Content="{DynamicResource L.Login.SwitchToV2}"
                                Style="{StaticResource Button.Danger}"
                                Command="{Binding SwitchToV2Command}"
                                HorizontalAlignment="Left" />
                    </StackPanel>
                </Border>

                <!-- Generic error -->
                <Border Background="{StaticResource Brush.DangerSoft}" CornerRadius="8" Padding="12,10" Margin="0,20,0,0"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource NullToCollapsed}}">
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource Brush.Danger}"
                               FontSize="13" TextWrapping="Wrap" />
                </Border>

            </StackPanel>
        </Border>
    </Grid>
</UserControl>
