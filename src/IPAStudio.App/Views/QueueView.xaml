<UserControl x:Class="IPAStudio.App.Views.QueueView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:IPAStudio.App.Converters">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:IconPathConverter x:Key="IconPath" />
        <conv:InitialConverter x:Key="Initial" />
        <conv:NullToCollapsedConverter x:Key="NullToCollapsed" />
        <conv:StageToLabelConverter x:Key="StageLabel" />
        <conv:StageToBrushConverter x:Key="StageBrush" />
    </UserControl.Resources>

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="{DynamicResource L.Queue.Title}" Style="{StaticResource Text.Title}" />
            <TextBlock Text="{Binding DeviceName}" Style="{StaticResource Text.Subtitle}" Margin="0,2,0,0" />
        </StackPanel>

        <!-- Overall progress card -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <Grid Margin="0,0,0,8">
                        <TextBlock Text="{DynamicResource L.Queue.Overall}" Style="{StaticResource Text.Body}"
                                   FontWeight="SemiBold" />
                        <TextBlock HorizontalAlignment="Right" Style="{StaticResource Text.Body}"
                                   FontWeight="SemiBold" Foreground="{StaticResource Brush.Accent}"
                                   Text="{Binding OverallProgress, StringFormat={}{0:0}%}" />
                    </Grid>
                    <ProgressBar Style="{StaticResource Progress.Slim}" Height="8"
                                 Value="{Binding OverallProgress, Mode=OneWay}" Maximum="100" />
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <Border Style="{StaticResource Badge}" Background="{StaticResource Brush.SuccessSoft}" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{DynamicResource L.Queue.Done}" Foreground="{StaticResource Brush.Success}" FontSize="11" />
                                <TextBlock Text="{Binding DoneCount, StringFormat=': {0}'}"
                                           Foreground="{StaticResource Brush.Success}" FontSize="11" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Badge}" Background="{StaticResource Brush.DangerSoft}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{DynamicResource L.Queue.Failed}" Foreground="{StaticResource Brush.Danger}" FontSize="11" />
                                <TextBlock Text="{Binding FailedCount, StringFormat=': {0}'}"
                                           Foreground="{StaticResource Brush.Danger}" FontSize="11" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
                <Button Grid.Column="1" Content="{DynamicResource L.Queue.CancelAll}" Style="{StaticResource Button.Danger}"
                        VerticalAlignment="Top" Margin="16,0,0,0"
                        Command="{Binding CancelCommand}"
                        Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}" />
            </Grid>
        </Border>

        <!-- Session-expired banner (shown when ipatool says "account file is not protected") -->
        <Border Grid.Row="2" Margin="0,0,0,0" Padding="16,12"
                CornerRadius="10" Background="{StaticResource Brush.DangerSoft}"
                BorderBrush="{StaticResource Brush.Danger}" BorderThickness="1"
                Visibility="{Binding SessionExpired, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="{DynamicResource L.Queue.SessionExpiredTitle}"
                               Foreground="{StaticResource Brush.Danger}" FontWeight="SemiBold" FontSize="13" />
                    <TextBlock Text="{DynamicResource L.Queue.SessionExpiredHint}"
                               Foreground="{StaticResource Brush.Danger}" FontSize="12" Margin="0,3,0,0"
                               TextWrapping="Wrap" />
                </StackPanel>
                <Button Grid.Column="1" Content="{DynamicResource L.Queue.SignInAgain}"
                        Style="{StaticResource Button.Danger}" VerticalAlignment="Center" Margin="16,0,0,0"
                        Command="{Binding SignInAgainCommand}" />
            </Grid>
        </Border>

        <!-- Per-item pipeline -->
        <Border Grid.Row="3" Style="{StaticResource Card}" Padding="4">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Items}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="8,4" Padding="14" CornerRadius="10"
                                    Background="{StaticResource Brush.Background}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Icon -->
                                    <Grid Grid.Column="0" Width="44" Height="44" Margin="0,0,14,0" VerticalAlignment="Top">
                                        <Border CornerRadius="10" Background="{StaticResource Brush.AccentSoft}">
                                            <TextBlock Text="{Binding Name, Converter={StaticResource Initial}}"
                                                       Foreground="{StaticResource Brush.Accent}" FontSize="18" FontWeight="SemiBold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <Border CornerRadius="10"
                                                Visibility="{Binding CachedIconPath, Converter={StaticResource NullToCollapsed}}">
                                            <Border.Background>
                                                <ImageBrush ImageSource="{Binding CachedIconPath, Converter={StaticResource IconPath}}"
                                                            Stretch="UniformToFill" />
                                            </Border.Background>
                                        </Border>
                                        <!-- Success check overlay -->
                                        <Border CornerRadius="10" Background="#CC30D158"
                                                Visibility="{Binding IsDone, Converter={StaticResource BoolToVis}}">
                                            <Path Data="M12,23 L19,30 L32,15" Stroke="White" StrokeThickness="3.5"
                                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                                  Stretch="None" />
                                        </Border>
                                    </Grid>

                                    <!-- Name, stage, progress -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <Grid>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Name}" Style="{StaticResource Text.Body}"
                                                           FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                <Border Style="{StaticResource Badge}" Margin="10,0,0,0"
                                                        Background="Transparent"
                                                        BorderBrush="{Binding Stage, Converter={StaticResource StageBrush}}"
                                                        BorderThickness="1">
                                                    <TextBlock Text="{Binding Stage, Converter={StaticResource StageLabel}}"
                                                               Foreground="{Binding Stage, Converter={StaticResource StageBrush}}"
                                                               FontSize="11" />
                                                </Border>
                                            </StackPanel>
                                            <TextBlock HorizontalAlignment="Right" Style="{StaticResource Text.Caption}"
                                                       Text="{Binding SpeedText}" />
                                        </Grid>

                                        <!-- Animated progress: only for active items -->
                                        <ProgressBar Style="{StaticResource Progress.Slim}" Margin="0,8,0,0"
                                                     Value="{Binding StageProgress, Mode=OneWay}" Maximum="100"
                                                     IsIndeterminate="{Binding IsIndeterminate}"
                                                     Foreground="{Binding Stage, Converter={StaticResource StageBrush}}"
                                                     Visibility="{Binding IsActive, Converter={StaticResource BoolToVis}}" />

                                        <TextBlock Text="{Binding StatusDetail}" Style="{StaticResource Text.Caption}"
                                                   Margin="0,6,0,0" />

                                        <!-- Error -->
                                        <TextBlock Text="{Binding ErrorMessage}" FontSize="12"
                                                   Foreground="{StaticResource Brush.Danger}" TextWrapping="Wrap"
                                                   Margin="0,4,0,0"
                                                   Visibility="{Binding ErrorMessage, Converter={StaticResource NullToCollapsed}}" />
                                    </StackPanel>

                                    <!-- Retry button for failed items -->
                                    <Button Grid.Column="2" Content="{DynamicResource L.Retry}"
                                            Style="{StaticResource Button.Secondary}" VerticalAlignment="Center"
                                            Margin="12,0,0,0"
                                            Visibility="{Binding IsFailed, Converter={StaticResource BoolToVis}}"
                                            Command="{Binding DataContext.RetryItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Footer -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="{DynamicResource L.Back}" Style="{StaticResource Button.Ghost}"
                    Command="{Binding BackToAppsCommand}" Margin="0,0,8,0" />
            <Button Content="{DynamicResource L.Queue.Finish}" Style="{StaticResource Button.Primary}"
                    Command="{Binding BackToDevicesCommand}"
                    Visibility="{Binding IsFinished, Converter={StaticResource BoolToVis}}" />
        </StackPanel>
    </Grid>
</UserControl>
