<UserControl x:Class="IPAStudio.App.Views.DeviceInfoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:IPAStudio.App.Converters">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:NullToCollapsedConverter x:Key="NullToCollapsed" />
        <conv:BatteryToBrushConverter x:Key="BatteryToBrush" />
    </UserControl.Resources>

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <StackPanel>
                <TextBlock Text="{DynamicResource L.DeviceInfo.Title}" Style="{StaticResource Text.Title}" />
                <TextBlock Text="{Binding ModelLine}" Style="{StaticResource Text.Subtitle}" Margin="0,4,0,0" />
            </StackPanel>
            <Button Content="{DynamicResource L.Back}" Style="{StaticResource Button.Ghost}"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Command="{Binding BackCommand}" />
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="640" HorizontalAlignment="Left">

                <!-- Apple ID -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="40" Height="40" CornerRadius="9" Margin="0,0,14,0"
                                Background="{StaticResource Brush.AccentSoft}">
                            <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                       Foreground="{StaticResource Brush.Accent}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{DynamicResource L.DeviceInfo.AppleId}"
                                       Style="{StaticResource Text.Caption}" />
                            <!-- Known Apple ID -->
                            <TextBlock Text="{Binding AppleId}" Style="{StaticResource Text.Body}"
                                       FontSize="15" FontWeight="SemiBold" Margin="0,2,0,0"
                                       Visibility="{Binding AppleId, Converter={StaticResource NullToCollapsed}}" />
                            <!-- Not available -->
                            <TextBlock Text="{DynamicResource L.DeviceInfo.AppleIdUnknown}"
                                       Style="{StaticResource Text.Caption}" TextWrapping="Wrap" Margin="0,2,0,0"
                                       Visibility="{Binding AppleId, Converter={StaticResource NullToCollapsed}, ConverterParameter=invert}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Battery -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,16"
                        Visibility="{Binding BatteryVisible, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="40" Height="40" CornerRadius="9" Margin="0,0,14,0"
                                Background="{StaticResource Brush.AccentSoft}">
                            <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="18"
                                       Foreground="{StaticResource Brush.Accent}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="&#xE83F;" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding BatteryCharging}" Value="True">
                                                <Setter Property="Text" Value="&#xEC08;" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{DynamicResource L.DeviceInfo.Battery}"
                                       Style="{StaticResource Text.Caption}" />
                            <ProgressBar Style="{StaticResource Progress.Slim}"
                                         Value="{Binding BatteryLevel, Mode=OneWay}" Maximum="100"
                                         Margin="0,6,0,4"
                                         Foreground="{Binding BatteryLevel, Converter={StaticResource BatteryToBrush}}" />
                        </StackPanel>
                        <TextBlock Grid.Column="2" VerticalAlignment="Center" Margin="14,0,0,0"
                                   Style="{StaticResource Text.Body}" FontWeight="SemiBold" FontSize="18"
                                   Foreground="{Binding BatteryLevel, Converter={StaticResource BatteryToBrush}}">
                            <TextBlock.Text>
                                <Binding Path="BatteryLevel" StringFormat="{}{0}%" />
                            </TextBlock.Text>
                        </TextBlock>
                    </Grid>
                </Border>

                <!-- Storage -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,16"
                        Visibility="{Binding StorageSummary, Converter={StaticResource NullToCollapsed}}">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource L.DeviceInfo.Storage}" Style="{StaticResource Text.Caption}" />
                        <ProgressBar Style="{StaticResource Progress.Slim}" Margin="0,10,0,8"
                                     Value="{Binding StorageUsedPercent, Mode=OneWay}" Maximum="100" />
                        <TextBlock Text="{Binding StorageSummary}" Style="{StaticResource Text.Caption}" />
                    </StackPanel>
                </Border>

                <!-- Loading indicator -->
                <StackPanel Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" Margin="0,0,0,16">
                    <ProgressBar Style="{StaticResource Progress.Slim}" IsIndeterminate="True" />
                    <TextBlock Text="{DynamicResource L.Loading}" Style="{StaticResource Text.Caption}" Margin="0,6,0,0" />
                </StackPanel>

                <!-- Details -->
                <Border Style="{StaticResource Card}">
                    <ItemsControl ItemsSource="{Binding Rows}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,7">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Label}" Style="{StaticResource Text.Caption}" />
                                    <TextBlock Grid.Column="1" Text="{Binding Value}" Style="{StaticResource Text.Body}"
                                               TextWrapping="Wrap" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
